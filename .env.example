MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=log_monitor
MYSQL_SSL_CA=

# Optional alternative to MYSQL_* values:
# DATABASE_URL=mysql://user:password@host:3306/log_monitor

# Comma-separated frontend origins. Replace with your Render frontend URL in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional alert integrations.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ALERT_RECEIVER=
ALERT_WEBHOOK_URL=
